# Environment variables for the service (SQLAlchemy ORM)
ENV=development
APP_NAME=ddd-service-orm-db

# SQLAlchemy database backend
# Available options: sqlite, postgresql, mariadb, mysql, mssql, oracle
DB_BACKEND=sqlite

# SQLite (when DB_BACKEND=sqlite)
DB_PATH=./data/app.db

# All other backends — set DB_DSN to skip individual fields
DB_USER=user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432        # varies by backend: postgresql=5432, mysql/mariadb=3306, mssql=1433, oracle=1521
DB_NAME=app
DB_DSN=

# Oracle only — service name replaces DB_NAME
DB_SERVICE=XEPDB1

# Set to true to echo SQL statements (debug mode)
SQL_ECHO=false

# Set to true to run the CRUD demo in main.py
RUN_DEMO=false
