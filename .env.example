ENV=development
APP_NAME=irpf

# Taxpayer identifier — maps to a dedicated PostgreSQL schema (your initials or alias)
# B3 Excel files must carry this prefix: <your-id>-movimentacao-2025*.xlsx
TAXPAYER=
# Full legal name and CPF as they appear in the Receita Federal IRPF program
TAXPAYER_FULL_NAME=
TAXPAYER_CPF=

# PostgreSQL
DB_BACKEND=postgresql
DB_USER=irpf_user
DB_PASSWORD=irpf_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wealth_db
DB_DSN=

SQL_ECHO=false
RUN_DEMO=false

# Database backup storage — absolute path to a mounted volume or local dir
# Example: /mnt/wd_irpf  (never commit a real path — keep this blank here)
BACKUP_STORE_PATH=

# pgAdmin
PGADMIN_EMAIL=admin@irpf.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
